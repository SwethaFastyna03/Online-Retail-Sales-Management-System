SQL>  COLUMN customer_name FORMAT A15
SQL> COLUMN product_name FORMAT A15


SQL> SELECT c.customer_name,
  2         p.product_name,
  3         oi.quantity
  4  FROM customers c
  5  JOIN orders o
  6  ON c.customer_id = o.customer_id
  7  JOIN order_items oi
  8  ON o.order_id = oi.order_id
  9  JOIN products p
 10  ON oi.product_id = p.product_id;

