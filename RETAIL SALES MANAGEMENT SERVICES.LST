SQL> 
SQL> CREATE TABLE CUSTOMERS(
  2  CUSTOMER_ID NUMBER PRIMARY KEY,
  3  CUSTOMER_NAME VARCHAR2(100),
  4  CITY VARCHAR2(50),
  5  PHONE VARCHAR2(15)
  6  );

Table created.

SQL> DESC CUSTOMERS;
 Name                                      Null?    Type
 ----------------------------------------- -------- ----------------------------
 CUSTOMER_ID                               NOT NULL NUMBER
 CUSTOMER_NAME                                      VARCHAR2(100)
 CITY                                               VARCHAR2(50)
 PHONE                                              VARCHAR2(15)


SQL> --CREATE PRODUCT TABLE--
SQL>  CREATE TABLE PRODUCTS(
  2  PRODUCT_ID NUMBER PRIMARY KEY,
  3  PRODUCT_NAME VARCHAR2(100),
  4  CATEGORY VARCHAR2(50),
  5  PRICE NUMBER(10,2),
  6  STOCK NUMBER );

Table created.

SQL> DESC PRODUCTS;
 Name                                      Null?    Type
 ----------------------------------------- -------- ----------------------------
 PRODUCT_ID                                NOT NULL NUMBER
 PRODUCT_NAME                                       VARCHAR2(100)
 CATEGORY                                           VARCHAR2(50)
 PRICE                                              NUMBER(10,2)
 STOCK                                              NUMBER


SQL>  CREATE TABLE ORDERS(
  2   ORDER_ID NUMBER PRIMARY KEY,
  3   CUSTOMER_ID NUMBER,
  4   ORDER_DATE DATE,
  5  CONSTRAINT FK_CUSTOMER
  6  FOREIGN KEY (CUSTOMER_ID)
  7  REFERENCES CUSTOMERS(CUSTOMER_ID));

Table created.

SQL> DESC ORDERS;
 Name                                      Null?    Type
 ----------------------------------------- -------- ----------------------------
 ORDER_ID                                  NOT NULL NUMBER
 CUSTOMER_ID                                        NUMBER
 ORDER_DATE                                         DATE
 
SQL> 
SQL> --CREATE ORDER_ITEMS TABLE
SQL> CREATE TABLE ORDER_ITEMS(
  2  ITEM_ID NUMBER PRIMARY KEY,
  3  ORDER_ID NUMBER,
  4  PRODUCT_ID NUMBER,
  5  QUANTITY NUMBER,
  6  TOTAL_PRICE NUMBER(10,2),
  7  CONSTRAINT FK_ORDER
  8  FOREIGN KEY (ORDER_ID)
  9  REFERENCES ORDERS(ORDER_ID),
 10  CONSTRAINT FK_PRODUCT
 11  FOREIGN KEY (PRODUCT_ID)
 12  REFERENCES PRODUCTS(PRODUCT_ID));

Table created.

SQL> DESC ORDER_ITEMS;
 Name                                      Null?    Type
 ----------------------------------------- -------- ----------------------------
 ITEM_ID                                   NOT NULL NUMBER
 ORDER_ID                                           NUMBER
 PRODUCT_ID                                         NUMBER
 QUANTITY                                           NUMBER
 TOTAL_PRICE                                        NUMBER(10,2)

