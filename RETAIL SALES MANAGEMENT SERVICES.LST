HEADSET                      2                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
LAPTOP                       1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
TABLET                       1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
PHONE                        1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          

SQL> --QUERY 4 MONTHLY REVENUE-
SQL>  SELECT TO_CHAR(o.order_date,'MONTH') AS month,
  2         SUM(oi.total_price) AS revenue
  3  FROM orders o
  4  JOIN order_items oi
  5  ON o.order_id = oi.order_id
  6  GROUP BY TO_CHAR(o.order_date,'MONTH');

MONTH        REVENUE                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
