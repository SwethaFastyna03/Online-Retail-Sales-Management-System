MAY           141000                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
 
SQL> SELECT c.customer_name,
  2         p.product_name,
  3         oi.quantity,
  4         oi.total_price
  5  FROM customers c
  6  JOIN orders o
  7  ON C.CUSTOMER_ID=O.CUSTOMER_ID
  8  JOIN ORDER_ITEMS OI
  9  ON O.ORDER_ID=OI.ORDER_ID
 10  JOIN PRODUCTS P
 11  ON OI.PRODUCT_ID=P.PRODUCT_ID;

